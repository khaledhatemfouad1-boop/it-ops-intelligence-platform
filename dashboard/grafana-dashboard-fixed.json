    {
      "id": 7, "type": "piechart", "title": "Tickets by Status",
      "gridPos": {"h":8,"w":8,"x":0,"y":5},
      "datasource": {"type":"postgres","uid":"ffg7u71m9acqoc"},
      "options": { "legend":{"displayMode":"table","placement":"right","showLegend":true,"values":["value","percent"]},"pieType":"donut","tooltip":{"mode":"single","sort":"none"} },
      "fieldConfig": { "defaults": { "color":{"mode":"palette-classic"}, "custom":{"hideFrom":{"legend":false,"tooltip":false,"viz":false}} }, "overrides":[] },
      "targets": [{ "datasource":{"type":"postgres","uid":"ffg7u71m9acqoc"}, "format":"table", "rawSql":"SELECT 'All Tickets' AS \"Category\", COUNT(*) AS \"Count\" FROM public.sdp_tickets UNION ALL SELECT 'Closed', COUNT(*) FROM public.sdp_tickets WHERE status IN ('Closed','Resolved','Closed - Resolved') UNION ALL SELECT 'Open', COUNT(*) FROM public.sdp_tickets WHERE status NOT IN ('Closed','Resolved','Closed - Resolved')", "refId":"A" }]
    },

    {
      "id": 8, "type": "piechart", "title": "Tickets by Priority",
      "gridPos": {"h":8,"w":8,"x":8,"y":5},
      "datasource": {"type":"postgres","uid":"ffg7u71m9acqoc"},
      "options": { "legend":{"displayMode":"table","placement":"right","showLegend":true,"values":["value","percent"]},"pieType":"donut","tooltip":{"mode":"single","sort":"none"} },
      "fieldConfig": { "defaults": { "color":{"mode":"palette-classic"}, "custom":{"hideFrom":{"legend":false,"tooltip":false,"viz":false}} }, "overrides":[] },
      "targets": [{ "datasource":{"type":"postgres","uid":"ffg7u71m9acqoc"}, "format":"table", "rawSql":"SELECT COALESCE(NULLIF(TRIM(priority),''), 'Unknown') AS \"Priority\", COUNT(*) AS \"Count\" FROM public.sdp_tickets GROUP BY priority ORDER BY CASE LOWER(TRIM(COALESCE(priority,''))) WHEN 'critical' THEN 1 WHEN 'high' THEN 2 WHEN 'medium' THEN 3 WHEN 'low' THEN 4 ELSE 5 END", "refId":"A" }]
    },

    {
      "id": 9, "type": "barchart", "title": "Technician with Most Assigned Tickets",
      "gridPos": {"h":8,"w":8,"x":16,"y":5},
      "datasource": {"type":"postgres","uid":"ffg7u71m9acqoc"},
      "options": { "barWidth":0.7,"fillOpacity":80,"gradientMode":"none","legend":{"displayMode":"list","placement":"bottom","showLegend":true},"orientation":"horizontal","tooltip":{"mode":"multi","sort":"desc"},"xTickLabelMaxLength":20,"xTickLabelRotation":0 },
      "fieldConfig": { "defaults": { "color":{"mode":"palette-classic"}, "custom":{"axisCenteredZero":false,"axisColorMode":"text","axisLabel":"","axisPlacement":"auto","fillOpacity":80,"gradientMode":"none","hideFrom":{"legend":false,"tooltip":false,"viz":false},"lineWidth":1,"scaleDistribution":{"type":"linear"},"thresholdsStyle":{"mode":"off"}} }, "overrides":[] },
      "targets": [{ "datasource":{"type":"postgres","uid":"ffg7u71m9acqoc"}, "format":"table", "rawSql":"SELECT COALESCE(NULLIF(TRIM(assignee),''), 'Unassigned') AS \"Technician\", COUNT(*) AS \"Total Assigned\", COUNT(*) FILTER (WHERE status NOT IN ('Closed','Resolved','Closed - Resolved')) AS \"Open\", COUNT(*) FILTER (WHERE is_overdue=TRUE AND status NOT IN ('Closed','Resolved','Closed - Resolved')) AS \"Overdue\" FROM public.sdp_tickets GROUP BY assignee ORDER BY \"Total Assigned\" DESC LIMIT 10", "refId":"A" }]
    },

    {
      "id": 10, "type": "table", "title": "Open Tickets — Overdue First",
      "gridPos": {"h":8,"w":24,"x":0,"y":13},
      "datasource": {"type":"postgres","uid":"ffg7u71m9acqoc"},
      "options": { "cellHeight":"sm","footer":{"countRows":false,"enablePagination":true,"fields":"","reducer":["sum"],"show":false},"showHeader":true },
      "fieldConfig": { "defaults": { "color":{"mode":"thresholds"}, "custom":{"align":"left","cellOptions":{"type":"auto"},"inspect":false}, "mappings":[], "thresholds":{"mode":"absolute","steps":[{"color":"green","value":null}]} },
        "overrides": [
          {"matcher":{"id":"byName","options":"is_overdue"},"properties":[{"id":"custom.cellOptions","value":{"type":"color-text"}},{"id":"mappings","value":[{"options":{"false":{"color":"green","index":1,"text":"No"},"true":{"color":"red","index":0,"text":"YES"}},"type":"value"}]},{"id":"thresholds","value":{"mode":"absolute","steps":[{"color":"green","value":null}]}}]},
          {"matcher":{"id":"byName","options":"priority"},"properties":[{"id":"custom.cellOptions","value":{"type":"color-background"}},{"id":"mappings","value":[{"options":{"Critical":{"color":"red","index":0},"High":{"color":"orange","index":1},"Low":{"color":"blue","index":3},"Medium":{"color":"yellow","index":2}},"type":"value"}]}]}
        ]
      },
      "targets": [{ "datasource":{"type":"postgres","uid":"ffg7u71m9acqoc"}, "format":"table", "rawSql":"SELECT ticket_id AS \"Ticket ID\", LEFT(COALESCE(subject,''), 60) AS \"Subject\", COALESCE(priority,'?') AS \"priority\", COALESCE(assignee,'Unassigned') AS \"Assignee\", COALESCE(status,'?') AS \"Status\", COALESCE(is_overdue,FALSE) AS \"is_overdue\", created_at AS \"Created\", due_date AS \"Due Date\" FROM public.sdp_tickets WHERE status NOT IN ('Closed','Resolved','Closed - Resolved') ORDER BY is_overdue DESC, CASE LOWER(TRIM(COALESCE(priority,''))) WHEN 'critical' THEN 1 WHEN 'high' THEN 2 WHEN 'medium' THEN 3 WHEN 'low' THEN 4 ELSE 5 END LIMIT 100", "refId":"A" }]
    },

