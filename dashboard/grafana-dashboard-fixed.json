      "targets": [{ "datasource":{"type":"postgres","uid":"ffg7u71m9acqoc"}, "format":"table", "rawSql":"SELECT COUNT(*) AS \"Critical\" FROM public.sdp_tickets WHERE LOWER(TRIM(COALESCE(priority,''))) = 'critical' AND status NOT IN ('Closed','Resolved','Closed - Resolved')", "refId":"A" }]
