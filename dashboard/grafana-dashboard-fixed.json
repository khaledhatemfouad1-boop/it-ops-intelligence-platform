      "gridPos": {"h":4,"w":4,"x":16,"y":1},
      "datasource": {"type":"postgres","uid":"ffg7u71m9acqoc"},
      "options": { "colorMode":"background","graphMode":"none","justifyMode":"center","orientation":"auto","reduceOptions":{"calcs":["lastNotNull"],"fields":"","values":false},"textMode":"auto" },
      "fieldConfig": { "defaults": { "color":{"mode":"thresholds"}, "decimals":1, "mappings":[], "thresholds":{"mode":"absolute","steps":[{"color":"red","value":null},{"color":"yellow","value":60},{"color":"green","value":80}]}, "unit":"percent" }, "overrides":[] },
      "targets": [{ "datasource":{"type":"postgres","uid":"ffg7u71m9acqoc"}, "format":"table", "rawSql":"SELECT ROUND(100.0 * COUNT(*) FILTER (WHERE status IN ('Closed','Resolved','Closed - Resolved')) / NULLIF(COUNT(*),0), 1) AS \"Resolution %\" FROM public.sdp_tickets", "refId":"A" }]
    },

    {
      "id": 6, "type": "stat", "title": "Overdue Rate",
      "gridPos": {"h":4,"w":4,"x":20,"y":1},
      "datasource": {"type":"postgres","uid":"ffg7u71m9acqoc"},
