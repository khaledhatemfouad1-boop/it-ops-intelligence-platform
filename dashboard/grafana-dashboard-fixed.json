      "targets": [{ "datasource":{"type":"postgres","uid":"ffg7u71m9acqoc"}, "format":"table", "rawSql":"SELECT ROUND(100.0 * COUNT(*) FILTER (WHERE is_overdue=TRUE AND status NOT IN ('Closed','Resolved')) / NULLIF(COUNT(*) FILTER (WHERE status NOT IN ('Closed','Resolved')),0), 1) AS \"Overdue %\" FROM public.sdp_tickets", "refId":"A" }]
